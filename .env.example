# Telegram Bot Token (получить у @BotFather)
TOKEN=your_bot_token_here

# ID администраторов (через запятую, числовые Telegram ID)
ADMINS=123456789

# Настройки PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_NAME=help_bot_db
DB_PASS=postgres_secret

# YooMoney токен (для оплаты через YooMoney)
# Получить: https://yoomoney.ru/transfer/mine
YOOMONEY_TOKEN=your_yoomoney_token_here

# Telegram Payments token (получить: @BotFather → Your Bot → Payments → Connect)
PAYMENT_TOKEN=

# ID канала для проверки подписки (формат: @channel_username или -100xxxxxxxxxx)
CHANNEL_ID=

# Постоянная ссылка-приглашение на канал для вступления/подачи заявки
# Формат: https://t.me/+xxxxxxxxxx (создать в настройках канала → пригласительные ссылки)
CHANNEL_INVITE_LINK=

# Прокси для обхода блокировок (опционально, формат: socks5://user:pass@host:port)
# Оставьте пустым, если прокси не нужен
PROXY_URL=

# Цена подписки в рублях
PAYMENT_PRICE_RUB=299
